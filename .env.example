# ---- Supabase ----
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SERVER ONLY — never expose to the browser/client bundle)
SUPABASE_SERVICE_ROLE_KEY=

# Name of the Supabase Storage bucket that holds captured frames.
# Should be PRIVATE in production; the app serves short-lived signed URLs.
SUPABASE_STORAGE_BUCKET=traffic-sign-frames
# How long signed image URLs remain valid (seconds). Default 300 (5 min).
SIGNED_IMAGE_URL_TTL_SECONDS=300

# ---- External AI model API ----
# Endpoint that receives a frame URL + metadata and returns detections.
AI_MODEL_API_URL=
# Bearer token for the model server (SERVER ONLY — never exposed to the browser).
AI_MODEL_API_KEY=
# AI mode: "mock" | "external" | "auto" (default: auto). "live" is a legacy alias for "external".
#   mock     -> always use the built-in mock detector (no external call)
#   external -> always call AI_MODEL_API_URL; errors clearly if URL is missing
#   auto     -> call the URL if set, otherwise use the mock detector
AI_MODEL_MODE=auto
# Per-request timeout for external calls (ms).
AI_MODEL_TIMEOUT_MS=15000
# Retries on transient failures only (timeout, network, 429/502/503/504).
AI_MODEL_MAX_RETRIES=1
# Linear backoff between retries (ms).
AI_MODEL_RETRY_BACKOFF_MS=500

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Duplicate-detection / localization tuning (optional) ----
# Distance threshold (meters) for matching a detection to an existing sign (15-30 recommended)
SIGN_MATCH_RADIUS_METERS=25
# Minimum confidence required before a detection is grouped into the sign inventory
MIN_GROUPING_CONFIDENCE=0.45
