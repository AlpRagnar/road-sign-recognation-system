# ---- Supabase ----
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SERVER ONLY — never expose to the browser/client bundle)
SUPABASE_SERVICE_ROLE_KEY=

# Name of the Supabase Storage bucket that holds captured frames.
# Should be PRIVATE in production; the app serves short-lived signed URLs.
SUPABASE_STORAGE_BUCKET=traffic-sign-frames
# How long signed image URLs remain valid (seconds). Default 300 (5 min).
SIGNED_IMAGE_URL_TTL_SECONDS=300

# ---- Storage quarantine / reconciliation (admin storage tools) ----
# Days an orphan candidate must sit in quarantine before it can be deleted (1-90).
STORAGE_QUARANTINE_GRACE_DAYS=7
# Reconciliation scan caps (clamped server-side).
STORAGE_RECONCILIATION_MAX_FOLDERS=100
STORAGE_RECONCILIATION_MAX_FILES_PER_FOLDER=200
# Max candidates deleted per request (1-100).
STORAGE_QUARANTINE_DELETE_BATCH_LIMIT=50

# ---- External AI model API ----
# Endpoint that receives a frame URL + metadata and returns detections.
AI_MODEL_API_URL=
# Bearer token for the model server (SERVER ONLY — never exposed to the browser).
AI_MODEL_API_KEY=
# AI mode: "mock" | "external" | "auto" (default: auto). "live" is a legacy alias for "external".
#   mock     -> always use the built-in mock detector (no external call)
#   external -> always call AI_MODEL_API_URL; errors clearly if URL is missing
#   auto     -> call the URL if set, otherwise use the mock detector
AI_MODEL_MODE=auto
# Per-request timeout for external calls (ms).
AI_MODEL_TIMEOUT_MS=15000
# Retries on transient failures only (timeout, network, 429/502/503/504).
AI_MODEL_MAX_RETRIES=1
# Linear backoff between retries (ms).
AI_MODEL_RETRY_BACKOFF_MS=500
# Admin AI observability: warn when failure rate (of external attempts) >= this %.
AI_FAILURE_RATE_WARNING_PERCENT=20
# Admin AI observability: time-series bucket size (minutes).
AI_TIMESERIES_BUCKET_MINUTES=60

# ---- Dashboard / operational analytics ----
# Dashboard summary source: auto | rpc | fallback (default auto: prefer DB RPC, fall back to JS).
DASHBOARD_ANALYTICS_SOURCE=auto
# Default day range for /admin/analytics daily snapshots (clamped 7-365).
DAILY_METRICS_DEFAULT_DAYS=30
# Number of missing snapshot days in range before /admin/analytics warns (clamped 1-90).
SNAPSHOT_GAP_WARNING_DAYS=2

# ---- Headless cron automation (server-only; see docs/CRON_AUTOMATION.md) ----
# Required bearer secret for /api/cron/* endpoints (Authorization: Bearer <CRON_SECRET>).
# If empty, cron endpoints return a 500 config error. Never sent to the client.
CRON_SECRET=
# Toggle individual cron jobs (true/false).
CRON_DAILY_METRICS_ENABLED=true
CRON_STORAGE_RECONCILIATION_ENABLED=true
# Reconciliation scan caps used by the cron endpoint (clamped server-side).
CRON_STORAGE_RECONCILIATION_MAX_FOLDERS=60
CRON_STORAGE_RECONCILIATION_MAX_FILES_PER_FOLDER=100

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Duplicate-detection / localization tuning (optional) ----
# Distance threshold (meters) for matching a detection to an existing sign (15-30 recommended)
SIGN_MATCH_RADIUS_METERS=25
# Minimum confidence required before a detection is grouped into the sign inventory
MIN_GROUPING_CONFIDENCE=0.45
